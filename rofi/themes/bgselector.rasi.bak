@import "colors.rasi"

* {
    background-color:            transparent;
    text-color:                  white;
}

configuration {
    modi:                        "drun";
    show-icons:                  true;
    drun-display-format:         "{name}";
    font:                        "JetBrains Mono Nerd Font 12";
}

window {
    enabled:                     true;
    fullscreen:                  false;

    location:                    center;
    anchor:                      center;
    width:                       90%;

    spacing:                     0px;
    border-radius:               10px;

    background-color:            transparent;
    transparency:                "real";

    cursor:                      "default";
}

mainbox {
    enabled:                     true;
    children:                    [ "listview" ];

    background-color:            transparent;
}

listview {
    enabled:                     true;
    layout:                      vertical;
    reverse:                     false;

    columns:                     5; /* Number of elements in a row */
    lines:                       1; /* One row */
    fixed-height:                true;
    fixed-columns:               true;

    padding:                     26px 36px;
    spacing:                     100px;
    border:                      0px;

    cycle:                       false;
    dynamic:                     true;
    scrollbar:                   false;

    background-color:            transparent;
}

element {
    enabled:                     true;
    orientation:                 vertical;
    children:                    [ "element-icon" ];

    expand:                      false;

    padding:                     0px;
    spacing:                     0px;
    border:                      5px;

    background-color:            transparent;

    cursor:                      pointer;
}

element-icon {
    size:                        50%;
    expand:                      false;

    padding:                     0px;

    cursor:                      inherit;
}

element selected.normal {
    background-color:            white;
}
