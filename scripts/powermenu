#!/usr/bin/env bash

shutdown="箚맓"   # power
reboot="箚쐣"     # restart
suspend="箚뮧"    # sleep
logout="箚뿽"     # logout

chosen="$(printf "%s\n%s\n%s\n%s\n" "$shutdown" "$reboot" "$suspend" "$logout" \
    | rofi -dmenu -config "$HOME/.config/rofi/powermenu.rasi")"

case "$chosen" in
  "$shutdown")
    poweroff
    ;;
  "$reboot")
    reboot
    ;;
  "$suspend")
    systemctl suspend
    ;;
  "$logout")
    hyprctl dispatch 'hl.dsp.exit()'
    ;;
  *)
    exit 0
    ;;
esac
